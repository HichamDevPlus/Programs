import pandas as pd
import numpy as np
import lightgbm as lgb
import joblib
from sklearn.model_selection import StratifiedKFold, KFold, GridSearchCV
from sklearn.metrics import (
    r2_score, mean_squared_error, mean_absolute_error, 
    mean_absolute_percentage_error, mean_squared_log_error, make_scorer
)
import warnings

def train_lgbm_regression_consolidated(df_train, df_test, target_col, random_state, n_folds, stratify_cols):
    """
    Trains LightGBM using Stratified CV and Grid Search.
    Returns a single consolidated performance DataFrame and saves model/predictions.
    """
    X_train = df_train.drop(columns=[target_col])
    y_train = df_train[target_col]
    X_test = df_test.drop(columns=[target_col])
    y_test = df_test[target_col]
    
    # 1. Setup CV Splits and Track Observation Counts
    splits = []
    fold_obs_counts = [] # To track N for train_in_fold and validation
    
    if stratify_cols and len(stratify_cols) > 0:
        strat_series = df_train[stratify_cols].astype(str).agg('-'.join, axis=1)
        cv_strategy = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        # We dummy-split here just to capture the counts (N) for each fold
        for t_idx, v_idx in cv_strategy.split(X_train, strat_series):
            splits.append((t_idx, v_idx))
            fold_obs_counts.append({'train_n': len(t_idx), 'val_n': len(v_idx)})
    else:
        cv_strategy = KFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        for t_idx, v_idx in cv_strategy.split(X_train):
            splits.append((t_idx, v_idx))
            fold_obs_counts.append({'train_n': len(t_idx), 'val_n': len(v_idx)})

    # 2. Scorer and Grid Search
    def safe_msle(y_true, y_pred):
        return mean_squared_log_error(np.clip(y_true, 0, None), np.clip(y_pred, 0, None))

    scoring = {
        'R2': 'r2', 'RMSE': 'neg_root_mean_squared_error',
        'MAE': 'neg_mean_absolute_error', 'MAPE': 'neg_mean_absolute_percentage_error',
        'MSLE': make_scorer(safe_msle, greater_is_better=False)
    }

    param_grid = {
        'n_estimators': [100, 200],
        'learning_rate': [0.05, 0.1],
        'max_depth': [-1, 5],
        'num_leaves': [31, 50]
    }

    grid = GridSearchCV(
        lgb.LGBMRegressor(random_state=random_state, verbose=-1),
        param_grid=param_grid, cv=splits, scoring=scoring, 
        refit='RMSE', n_jobs=-1, return_train_score=True
    )
    
    print("Fitting model...")
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        grid.fit(X_train, y_train)

    # 3. Save model & Generate Predictions
    best_model = grid.best_estimator_
    joblib.dump(best_model, 'best_lgbm_model.pkl')
    
    train_preds = best_model.predict(X_train)
    test_preds = best_model.predict(X_test)

    # 4. Building the Consolidated Results List
    results_list = []
    cv_res = grid.cv_results_
    idx = grid.best_index_

    # A. Add Fold-by-Fold results
    for i in range(n_folds):
        # Train in fold
        results_list.append({
            'Rank/Fold': f"Fold {i+1}", 'Sample Type': 'train in fold', 'N': fold_obs_counts[i]['train_n'],
            'R2': cv_res[f'split{i}_train_R2'][idx], 'RMSE': -cv_res[f'split{i}_train_RMSE'][idx],
            'MAE': -cv_res[f'split{i}_train_MAE'][idx], 'MAPE': -cv_res[f'split{i}_train_MAPE'][idx],
            'MSLE': -cv_res[f'split{i}_train_MSLE'][idx]
        })
        # Validation
        results_list.append({
            'Rank/Fold': f"Fold {i+1}", 'Sample Type': 'validation', 'N': fold_obs_counts[i]['val_n'],
            'R2': cv_res[f'split{i}_test_R2'][idx], 'RMSE': -cv_res[f'split{i}_test_RMSE'][idx],
            'MAE': -cv_res[f'split{i}_test_MAE'][idx], 'MAPE': -cv_res[f'split{i}_test_MAPE'][idx],
            'MSLE': -cv_res[f'split{i}_test_MSLE'][idx]
        })

    # B. Add Full Train and Test results
    def get_metrics_row(y_true, y_pred, label):
        return {
            'Rank/Fold': 'N/A', 'Sample Type': label, 'N': len(y_true),
            'R2': r2_score(y_true, y_pred), 'RMSE': np.sqrt(mean_squared_error(y_true, y_pred)),
            'MAE': mean_absolute_error(y_true, y_pred), 'MAPE': mean_absolute_percentage_error(y_true, y_pred),
            'MSLE': safe_msle(y_true, y_pred)
        }

    results_list.append(get_metrics_row(y_train, train_preds, 'full train'))
    results_list.append(get_metrics_row(y_test, test_preds, 'test'))

    df_results = pd.DataFrame(results_list)

    # 5. Export Predictions to CSV
    df_train.assign(Pred=train_preds).to_csv('train_predictions.csv', index=False)
    df_test.assign(Pred=test_preds).to_csv('test_predictions.csv', index=False)

    print("Success: Model saved, CSVs generated, and performance table compiled.")
    return df_results

import pandas as pd
import numpy as np
import lightgbm as lgb
import joblib
from sklearn.model_selection import StratifiedKFold, KFold, GridSearchCV
from sklearn.metrics import (
    r2_score, 
    mean_squared_error, 
    mean_absolute_error, 
    mean_absolute_percentage_error
)
import warnings

def train_lgbm_regression_v3(df_train, df_test, target_col, random_state, n_folds, stratify_cols):
    """
    Trains LGBM with a unified performance table (Fold 0 = Overall)
    and detailed feature importance (Gain-based).
    """
    X_train = df_train.drop(columns=[target_col])
    y_train = df_train[target_col]
    X_test = df_test.drop(columns=[target_col])
    y_test = df_test[target_col]
    
    # --- 1. CV Strategy ---
    if stratify_cols and len(stratify_cols) > 0:
        stratify_series = df_train[stratify_cols].astype(str).agg('-'.join, axis=1)
        skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        splits = list(skf.split(np.zeros(len(df_train)), stratify_series))
    else:
        kf = KFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        splits = list(kf.split(X_train))

    # --- 2. Grid Search ---
    scoring = {
        'R2': 'r2',
        'RMSE': 'neg_root_mean_squared_error',
        'MAE': 'neg_mean_absolute_error',
        'MAPE': 'neg_mean_absolute_percentage_error'
    }
    param_grid = {
        'n_estimators': [50, 100],
        'learning_rate': [0.05, 0.1],
        'max_depth': [-1, 5],
        'num_leaves': [31, 50]
    }

    lgbm = lgb.LGBMRegressor(random_state=random_state, verbose=-1)
    
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        grid = GridSearchCV(
            estimator=lgbm, param_grid=param_grid, cv=splits, 
            scoring=scoring, refit='RMSE', n_jobs=-1, return_train_score=True
        )
        grid.fit(X_train, y_train)

    best_model = grid.best_estimator_
    
    # --- 3. Internal Metrics Helper ---
    def get_row_metrics(y_true, y_pred, fold_num, set_type):
        residuals = y_true - y_pred
        return {
            'Fold': fold_num,
            'Type': set_type,
            'N_Obs': len(y_true),
            'Mean_Target': np.mean(y_true),
            'R2': r2_score(y_true, y_pred),
            'RMSE': np.sqrt(mean_squared_error(y_true, y_pred)),
            'MAE': mean_absolute_error(y_true, y_pred),
            'MAPE': mean_absolute_percentage_error(y_true, y_pred),
            'Std_Residuals': np.std(residuals)
        }

    all_performance_rows = []

    # --- 4. Overall Results (Fold 0) ---
    train_preds = best_model.predict(X_train)
    test_preds = best_model.predict(X_test)
    
    all_performance_rows.append(get_row_metrics(y_train, train_preds, 0, 'Overall_Train'))
    all_performance_rows.append(get_row_metrics(y_test, test_preds, 0, 'Overall_Test'))

    # --- 5. Per-Fold Results ---
    # We use the best model to predict on each fold's split for consistency
    for i in range(n_folds):
        train_idx, val_idx = splits[i]
        
        # Validation Fold
        y_val_fold = y_train.iloc[val_idx]
        preds_val_fold = best_model.predict(X_train.iloc[val_idx])
        all_performance_rows.append(get_row_metrics(y_val_fold, preds_val_fold, i + 1, 'Validation'))
        
        # Training Fold
        y_train_fold = y_train.iloc[train_idx]
        preds_train_fold = best_model.predict(X_train.iloc[train_idx])
        all_performance_rows.append(get_row_metrics(y_train_fold, preds_train_fold, i + 1, 'Train'))

    df_performance_final = pd.DataFrame(all_performance_rows)

    # --- 6. Interpretability (Feature Importance) ---
    # Using 'gain' as it's the most appropriate for regression impact analysis
    importances = best_model.booster_.feature_importance(importance_type='gain')
    df_importance = pd.DataFrame({
        'Feature': X_train.columns,
        'Importance_Gain': importances
    }).sort_values(by='Importance_Gain', ascending=False).reset_index(drop=True)

    return df_performance_final, df_importance

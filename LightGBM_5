import pandas as pd
import numpy as np
import lightgbm as lgb
import joblib
from sklearn.model_selection import StratifiedKFold, KFold, GridSearchCV
from sklearn.metrics import (
    r2_score, mean_squared_error, mean_absolute_error, 
    mean_absolute_percentage_error, mean_squared_log_error, make_scorer
)
import warnings

def train_lgbm_expert_system(df_train, df_test, target_col, random_state, n_folds, stratify_cols):
    """
    Returns:
    - df_results: Table matching user-provided image structure.
    - df_importance: Feature importance based on Gain.
    Saves: model.pkl, train_predictions.csv, test_predictions.csv.
    """
    X_train = df_train.drop(columns=[target_col])
    y_train = df_train[target_col]
    X_test = df_test.drop(columns=[target_col])
    y_test = df_test[target_col]
    
    # 1. Custom CV Strategy (Stratification for Regression)
    if stratify_cols:
        strat_series = df_train[stratify_cols].astype(str).agg('-'.join, axis=1)
        cv_strategy = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        splits = list(cv_strategy.split(X_train, strat_series))
    else:
        cv_strategy = KFold(n_splits=n_folds, shuffle=True, random_state=random_state)
        splits = list(cv_strategy.split(X_train))

    # 2. Metric Scorers
    def safe_msle(y_true, y_pred):
        return mean_squared_log_error(np.clip(y_true, 0, None), np.clip(y_pred, 0, None))

    scoring = {'RMSE': 'neg_root_mean_squared_error'}
    param_grid = {'n_estimators': [100, 200], 'learning_rate': [0.05, 0.1], 'max_depth': [-1, 5]}

    # 3. Optimization
    grid = GridSearchCV(
        lgb.LGBMRegressor(random_state=random_state, verbose=-1),
        param_grid=param_grid, cv=splits, scoring=scoring, 
        refit='RMSE', n_jobs=-1, return_train_score=True
    )
    
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        grid.fit(X_train, y_train)

    best_params = grid.best_params_
    best_model = grid.best_estimator_
    
    # 4. Generate Fold-by-Fold Metrics
    results_rows = []
    metrics_cols = ['R^2', 'RMSE', 'MAE', 'MAPE', 'MSLE']

    for i, (t_idx, v_idx) in enumerate(splits):
        # We re-fit best params on each fold to get residuals and training stats
        model_fold = lgb.LGBMRegressor(**best_params, random_state=random_state, verbose=-1)
        model_fold.fit(X_train.iloc[t_idx], y_train.iloc[t_idx])
        
        for sample_label, idxs in [('Train', t_idx), ('Validation', v_idx)]:
            y_true_fold = y_train.iloc[idxs]
            y_pred_fold = model_fold.predict(X_train.iloc[idxs])
            
            row = {
                'Fold Number': i + 1,
                'Sample': sample_label,
                'Number of observations': len(idxs),
                'R^2': r2_score(y_true_fold, y_pred_fold),
                'RMSE': np.sqrt(mean_squared_error(y_true_fold, y_pred_fold)),
                'MAE': mean_absolute_error(y_true_fold, y_pred_fold),
                'MAPE': mean_absolute_percentage_error(y_true_fold, y_pred_fold),
                'MSLE': safe_msle(y_true_fold, y_pred_fold),
                'STD': np.std(y_true_fold - y_pred_fold) # Residual STD
            }
            results_rows.append(row)

    df_folds = pd.DataFrame(results_rows)

    # 5. Summary Statistics (Mean & Std Dev of metrics across folds)
    summary_list = []
    for s_type in ['Train', 'Validation']:
        subset = df_folds[df_folds['Sample'] == s_type]
        # MEAN row
        mean_row = {'Fold Number': 'CV Summary', 'Sample': f'MEAN {s_type}', 'Number of observations': subset['Number of observations'].mean()}
        for col in metrics_cols + ['STD']: mean_row[col] = subset[col].mean()
        summary_list.append(mean_row)
        # STD row (Variance between folds)
        std_row = {'Fold Number': 'CV Summary', 'Sample': f'STD {s_type}', 'Number of observations': subset['Number of observations'].std()}
        for col in metrics_cols + ['STD']: std_row[col] = subset[col].std()
        summary_list.append(std_row)

    # 6. Final Model (Full Train & Test)
    y_tr_pred, y_ts_pred = best_model.predict(X_train), best_model.predict(X_test)
    final_rows = []
    for label, y_t, y_p in [('Full Train', y_train, y_tr_pred), ('Test', y_test, y_ts_pred)]:
        final_rows.append({
            'Fold Number': 'X', 'Sample': label, 'Number of observations': len(y_t),
            'R^2': r2_score(y_t, y_p), 'RMSE': np.sqrt(mean_squared_error(y_t, y_p)),
            'MAE': mean_absolute_error(y_t, y_p), 'MAPE': mean_absolute_percentage_error(y_t, y_p),
            'MSLE': safe_msle(y_t, y_p), 'STD': np.std(y_t - y_p)
        })

    # Combine everything for df_results
    df_results = pd.concat([df_folds, pd.DataFrame(summary_list), pd.DataFrame(final_rows)], ignore_index=True)

    # 7. Feature Importance (Total Gain Approach)
    importances = best_model.booster_.feature_importance(importance_type='gain')
    df_importance = pd.DataFrame({
        'Feature': X_train.columns,
        'Total_Gain': importances
    }).sort_values(by='Total_Gain', ascending=False)
    df_importance['Percentage'] = (df_importance['Total_Gain'] / df_importance['Total_Gain'].sum()) * 100

    # 8. File Exports
    joblib.dump(best_model, 'best_lgbm_model.pkl')
    df_train.assign(Predictions=y_tr_pred).to_csv('df_Train_with_Predictions.csv', index=False)
    df_test.assign(Predictions=y_ts_pred).to_csv('df_Test_with_Predictions.csv', index=False)

    return df_results, df_importance

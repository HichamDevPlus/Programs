import os
import sys
import json
import platform
import numpy as np
import pandas as pd
import lightgbm as lgb
import shap
import matplotlib.pyplot as plt

from lightgbm import LGBMRegressor
from sklearn.metrics import (
    mean_squared_error,
    mean_absolute_error,
    median_absolute_error,
    mean_absolute_percentage_error,
    r2_score,
    explained_variance_score,
    max_error
)

def train_and_evaluate_lightgbm(df_train, df_test, target_col, hyperparams_json_path, output_dir="lgbm_outputs"):
    """
    Builds a LightGBM regression model, evaluates it, and exports metrics, 
    diagnostics, and explainability artifacts.
    """
    
    # Create output directory if it doesn't exist
    os.makedirs(output_dir, exist_ok=True)
    
    # 1. Prepare Data
    X_train = df_train.drop(columns=[target_col])
    y_train = df_train[target_col]
    X_test = df_test.drop(columns=[target_col])
    y_test = df_test[target_col]
    
    # 2. Load Hyperparameters
    with open(hyperparams_json_path, 'r') as f:
        hyperparams = json.load(f)
        
    # 3. Initialize and Train Model (Scikit-learn API)
    print("Training LightGBM model...")
    model = LGBMRegressor(**hyperparams)
    model.fit(X_train, y_train)
    
    # 4. Predictions and Residuals
    train_preds = model.predict(X_train)
    test_preds = model.predict(X_test)
    
    train_resids = y_train - train_preds
    test_resids = y_test - test_preds
    
    # Prepare CSV dataframes
    df_train_out = X_train.copy()
    df_train_out['Actual'] = y_train
    df_train_out['Prediction'] = train_preds
    df_train_out['Residual'] = train_resids
    
    df_test_out = X_test.copy()
    df_test_out['Actual'] = y_test
    df_test_out['Prediction'] = test_preds
    df_test_out['Residual'] = test_resids
    
    # Export CSVs
    df_train_out.to_csv(os.path.join(output_dir, "train_predictions_residuals.csv"), index=False)
    df_test_out.to_csv(os.path.join(output_dir, "test_predictions_residuals.csv"), index=False)
    
    # 5. Calculate Metrics
    def calculate_metrics(y_true, y_pred):
        return {
            "Number of observations": len(y_true),
            "Root Mean Squared Error": np.sqrt(mean_squared_error(y_true, y_pred)),
            "Mean Squared Error": mean_squared_error(y_true, y_pred),
            "Mean Absolute Error": mean_absolute_error(y_true, y_pred),
            "Median Absolute Error": median_absolute_error(y_true, y_pred),
            "Mean Absolute Percentage Error": mean_absolute_percentage_error(y_true, y_pred),
            "Coefficient of Determination": r2_score(y_true, y_pred),
            "Explained Variance Score": explained_variance_score(y_true, y_pred),
            "Maximum Residual Error": max_error(y_true, y_pred)
        }
        
    metrics_train = calculate_metrics(y_train, train_preds)
    metrics_test = calculate_metrics(y_test, test_preds)
    
    # Create Metrics DataFrame
    df_metrics = pd.DataFrame([metrics_train, metrics_test], index=['Train', 'Test']).T
    
    # 6. SHAP Values
    print("Calculating SHAP values...")
    explainer = shap.TreeExplainer(model)
    # Note: SHAP values are typically calculated on the test set for model generalization explainability
    shap_values_array = explainer.shap_values(X_test) 
    df_shap = pd.DataFrame(shap_values_array, columns=X_test.columns)
    
    # 7. Export Model (TXT) and Hyperparameters (JSON)
    model.booster_.save_model(os.path.join(output_dir, "lgbm_model_tree.txt"))
    
    all_params = model.get_params()
    with open(os.path.join(output_dir, "lgbm_all_hyperparameters.json"), 'w') as f:
        json.dump(all_params, f, indent=4)
        
    # 8. Export Environment Versions (TXT)
    with open(os.path.join(output_dir, "libraries_versions.txt"), 'w') as f:
        f.write(f"pandas: {pd.__version__}\n")
        f.write(f"numpy: {np.__version__}\n")
        f.write(f"lightgbm: {lgb.__version__}\n")
        f.write(f"shap: {shap.__version__}\n")
        # Scikit-learn version
        import sklearn
        f.write(f"scikit-learn: {sklearn.__version__}\n")
        
    with open(os.path.join(output_dir, "os_python_versions.txt"), 'w') as f:
        f.write(f"OS: {platform.platform()}\n")
        f.write(f"Python: {sys.version}\n")
        
    # 9. Export Excel File (Metrics + SHAP)
    excel_path = os.path.join(output_dir, "evaluation_and_shap.xlsx")
    with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:
        df_metrics.to_excel(writer, sheet_name='Metrics')
        df_shap.to_excel(writer, sheet_name='SHAP_Values', index=False)
        
    # 10. Generate and Save SHAP Plot
    plt.figure(figsize=(10, 6))
    shap.summary_plot(shap_values_array, X_test, show=False)
    plt.tight_layout()
    plt.savefig(os.path.join(output_dir, "shap_summary_plot.png"), dpi=300)
    plt.close()
    
    print(f"Success! All artifacts have been saved to the '{output_dir}' directory.")
    
    return df_metrics, df_shap

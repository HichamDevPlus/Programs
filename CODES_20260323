# How to use it:
#######################################################
from sklearn.datasets import make_regression
from sklearn.model_selection import train_test_split
import json

# 1. Generate dummy data
X, y = make_regression(n_samples=1000, n_features=10, noise=0.1, random_state=42)
df = pd.DataFrame(X, columns=[f'feature_{i}' for i in range(10)])
df['target'] = y

# Split into train/test DataFrames
df_train, df_test = train_test_split(df, test_size=0.2, random_state=42)

# 2. Create a dummy hyperparameters JSON file
params = {
    "n_estimators": 100,
    "learning_rate": 0.05,
    "max_depth": 5,
    "random_state": 42
}
with open('params.json', 'w') as f:
    json.dump(params, f)

# 3. Call the function
metrics_df, shap_df = train_and_evaluate_lightgbm(
    df_train=df_train,
    df_test=df_test,
    target_col='target',
    hyperparams_json_path='params.json',
    output_dir='./my_model_results'
)

# Preview the returned metrics
print(metrics_df)

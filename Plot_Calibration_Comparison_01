import matplotlib.pyplot as plt
from sklearn.calibration import calibration_curve

def Plot_Calibration_Comparison(df_test_results, target_col):
    """
    Plots the calibration curves for both Champion and Challenger models.
    Assumes df_test_results is the CSV output from the previous step.
    """
    plt.figure(figsize=(10, 7))
    
    # 1. Calculate Calibration for Champion
    prob_true_champ, prob_pred_champ = calibration_curve(
        df_test_results[target_col], 
        df_test_results['champ_prob'], 
        n_bins=10
    )
    
    # 2. Calculate Calibration for Challenger
    prob_true_chall, prob_pred_chall = calibration_curve(
        df_test_results[target_col], 
        df_test_results['chall_prob'], 
        n_bins=10
    )
    
    # 3. Plotting
    plt.plot(prob_pred_champ, prob_true_champ, marker='o', linewidth=2, label='Champion (Original)')
    plt.plot(prob_pred_chall, prob_true_chall, marker='s', linestyle='--', label='Challenger (Reproduction)')
    
    # Reference line (Perfect Calibration)
    plt.plot([0, 1], [0, 1], linestyle=':', color='black', label='Perfectly Calibrated')
    
    plt.xlabel('Mean Predicted Probability')
    plt.ylabel('Fraction of Positives (Actuals)')
    plt.title('Calibration Curve: Champion vs. Challenger')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.show()


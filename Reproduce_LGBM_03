import pickle
import lightgbm as lgb
import pandas as pd
import numpy as np
from sklearn.metrics import roc_auc_score, mean_squared_error

def audit_and_export_lgbm(df_train, df_test, target_col, pkl_path):
    """
    Reproduces a LightGBM model, compares predictions, and exports 
    datasets with prediction columns to CSV.
    """
    # 1. Load the "Champion" model
    with open(pkl_path, 'rb') as f:
        champion_model = pickle.load(f)

    # 2. Identify Model Type & Extract Params
    if hasattr(champion_model, 'get_params'):
        params = champion_model.get_params()
        is_classifier = isinstance(champion_model, lgb.LGBMClassifier)
    else:
        params = champion_model.params
        obj = params.get('objective', '')
        is_classifier = any(x in obj for x in ['binary', 'multiclass', 'softmax'])

    # 3. Train the "Challenger" model (The Reproduction Step)
    X_train = df_train.drop(columns=[target_col])
    y_train = df_train[target_col]
    X_test = df_test.drop(columns=[target_col])
    
    if is_classifier:
        challenger_model = lgb.LGBMClassifier(**params)
    else:
        challenger_model = lgb.LGBMRegressor(**params)
        
    challenger_model.fit(X_train, y_train)

    # 4. Generate Predictions for Export
    # We add 'champion_pred' (from pkl) and 'challenger_pred' (your reproduction)
    # to see if they differ on a row-by-row basis.
    for label, df, X in [('train', df_train.copy(), X_train), 
                         ('test', df_test.copy(), X_test)]:
        
        if is_classifier:
            # For classifiers, we export the probability of the positive class
            df['champion_prob'] = champion_model.predict_proba(X)[:, 1]
            df['challenger_prob'] = challenger_model.predict_proba(X)[:, 1]
            # Also add the final class prediction
            df['champion_class'] = champion_model.predict(X)
        else:
            df['champion_pred'] = champion_model.predict(X)
            df['challenger_pred'] = challenger_model.predict(X)

        # 5. Export to CSV with ';' separator
        file_name = f"reproduction_{label}_results.csv"
        df.to_csv(file_name, sep=';', index=False)
        print(f"✅ Exported: {file_name}")

    # 6. Basic Validation Printout
    y_test = df_test[target_col]
    if is_classifier:
        score = roc_auc_score(y_test, champion_model.predict_proba(X_test)[:, 1])
        print(f"Champion Test ROC-AUC: {score:.4f}")
    else:
        score = mean_squared_error(y_test, champion_model.predict(X_test))
        print(f"Champion Test MSE: {score:.4f}")

    return champion_model, challenger_model


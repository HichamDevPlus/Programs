import lightgbm as lgb
import numpy as np
import pandas as pd
from sklearn.datasets import make_regression

# 1. Setup: Create some dummy data and a basic model
# (In your review, this would be the developer's actual data and model)
X, y = make_regression(n_samples=1000, n_features=10, random_state=42)
feature_names = [f'feature_{i}' for i in range(10)]
X_df = pd.DataFrame(X, columns=feature_names)

# Train a quick in-memory model
train_data = lgb.Dataset(X_df, label=y)
original_model = lgb.train({'objective': 'regression'}, train_data, num_boost_round=10)

# ---------------------------------------------------------
# THE SANITY CHECK PROCESS STARTS HERE
# ---------------------------------------------------------

# Step 1: Get a small test batch (e.g., the first 5 rows of the training set)
# ALWAYS use a pandas DataFrame if the model was trained on one, to keep column names
test_batch = X_df.head(5)

# Step 2: Generate baseline predictions from the ORIGINAL model
original_preds = original_model.predict(test_batch)

# Step 3: Export the model to a file
model_filepath = 'review_model.txt'
original_model.save_model(model_filepath)

# Step 4: Load the model from the file (Simulating your review environment)
loaded_model = lgb.Booster(model_file=model_filepath)

# Step 5: Generate new predictions from the LOADED model
loaded_preds = loaded_model.predict(test_batch)

# Step 6: The Mathematical Verification
print("--- Prediction Comparison ---")
print(f"Original: {original_preds}")
print(f"Loaded:   {loaded_preds}\n")

# Use np.allclose to check if arrays are equal within a tiny tolerance (default 1e-05)
are_identical = np.allclose(original_preds, loaded_preds)

if are_identical:
    print("✅ SANITY CHECK PASSED: The loaded model produces identical predictions.")
else:
    print("❌ SANITY CHECK FAILED: The predictions differ!")
    
    # Calculate the maximum absolute difference to see how far off it is
    max_diff = np.max(np.abs(original_preds - loaded_preds))
    print(f"Maximum difference observed: {max_diff}")

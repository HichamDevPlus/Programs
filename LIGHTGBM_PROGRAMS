# First, install it if you haven't: pip install shap

import shap
import matplotlib.pyplot as plt

# 1. Initialize the Explainer using your LOADED model
# SHAP understands LightGBM native booster objects perfectly
explainer = shap.TreeExplainer(loaded_model)

# 2. Calculate SHAP values for your test data
# We use the X_df from the previous step (it must be a pandas DataFrame for feature names)
shap_values = explainer.shap_values(X_df)

# Note: For regression, shap_values is a single matrix. 
# For binary classification, it returns a list of two matrices (one for each class).


# A. The Global View: Summary Plot (Feature Importance + Direction)
# A standard feature importance chart tells you which features matter. 
# The SHAP Summary Plot tells you which features matter AND how they impact the prediction (positively or negatively).
# Generate the summary plot
shap.summary_plot(shap_values, X_df)

# B. The Relationship View: Dependence Plot
# This plot isolates a single feature to show you exactly how the model treats its values across the entire dataset. 
# It is the modern alternative to Partial Dependence Plots.
# Show how 'feature_0' impacts the prediction, and automatically color by an interacting feature
shap.dependence_plot('feature_0', shap_values, X_df)

# C. The Local View: Waterfall Plot (Individual Prediction)
# As a reviewer, you should pick a few extreme cases (e.g., 
# the highest prediction and the lowest prediction) and break them down individually.
# Explain the very first prediction in the dataset
shap.waterfall_plot(shap.Explanation(values=shap_values[0], 
                                     base_values=explainer.expected_value, 
                                     data=X_df.iloc[0],  
                                     feature_names=X_df.columns))

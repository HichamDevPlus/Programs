# Categorical features are where LightGBM really flexes its muscles. 
# Most algorithms (like XGBoost or standard Scikit-Learn Decision Trees) require you to One-Hot Encode categorical data, 
# which can turn a single column into hundreds of sparse columns, making the model slow and prone to overfitting.
# LightGBM doesn't do that. It uses a specialized algorithm to find the optimal split among categories directly.

import lightgbm as lgb
import pandas as pd

# 1. Create a dummy dataset with categorical data
data = pd.DataFrame({
    'city': ['London', 'Paris', 'Berlin', 'London', 'Berlin'],
    'size': [100, 150, 120, 110, 130],
    'price': [500, 700, 600, 520, 630]
})

# 2. IMPORTANT: Convert object columns to 'category' type
data['city'] = data['city'].astype('category')

X = data[['city', 'size']]
y = data['price']

# 3. Create Dataset and specify categorical features
# LightGBM will automatically detect 'category' types, 
# but being explicit is safer.
train_data = lgb.Dataset(X, label=y, categorical_feature=['city'])

params = {
    'objective': 'regression',
    'metric': 'rmse',
    'verbose': -1
}

# 4. Train - LightGBM handles the 'city' column natively
model = lgb.train(params, train_data)
